<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" prefHeight="467.0" prefWidth="600.0" style="-fx-background-color: #ffffff;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.ListagemVendasController">

   <children>

      <Button fx:id="btnInfo" layoutX="245.0" layoutY="355.0" mnemonicParsing="false" onAction="#btnInfoClick" prefHeight="30.0" prefWidth="110.0" style="-fx-background-color: #A7D7C5; -fx-text-fill: #2d3748; -fx-font-weight: bold; -fx-border-color: #2f855a; -fx-border-width: 2px; -fx-border-radius: 5px;" text="Info">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Button>

      <TextField fx:id="txtPesquisar" layoutX="65.0" layoutY="82.0" prefHeight="30.0" prefWidth="470.0" promptText="Insira a busca" style="-fx-background-color: #f7fafc; -fx-border-color: #e2e8f0; -fx-text-fill: #2d3748;">
         <font>
            <Font size="14.0" />
         </font>
      </TextField>

      <TableView fx:id="tabelaUsuarios" layoutX="65.0" layoutY="127.0" onMouseClicked="#TableViewClick" prefHeight="200.0" prefWidth="470.0" />

      <Button fx:id="btnFechar" layoutX="245.0" layoutY="408.0" mnemonicParsing="false" onAction="#btnFecharClick" prefHeight="30.0" prefWidth="110.0" style="-fx-background-color: #A7D7C5; -fx-text-fill: #2d3748; -fx-font-weight: bold; -fx-border-color: #2f855a; -fx-border-width: 2px; -fx-border-radius: 5px;" text="Fechar">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Button>

      <Label layoutX="88.0" layoutY="24.0" style="-fx-text-fill: #2d3748;" text="LISTAGEM DE VENDAS DO SISTEMA">
         <font>
            <Font name="System Bold" size="25.0" />
         </font>
      </Label>

   </children>
</AnchorPane>
